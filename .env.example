# =============================================================================
# AI Employee — Environment Variables
# Copy to .env.cloud (Cloud VM) or .env.local (Local machine) and fill values
# NEVER commit the actual .env files — they are in .gitignore
# =============================================================================

# --- Vault ---
# Absolute path to the AI_Employee_Vault directory on this machine
VAULT_PATH=/path/to/AI_Employee_Vault

# Which agent this instance runs as: cloud | local
AGENT_ROLE=cloud

# Semantic version of the agent code
AGENT_VERSION=1.0.0

# --- Git Sync ---
# Name of the git remote to push/pull (usually "origin")
VAULT_GIT_REMOTE=origin

# Seconds between periodic vault pulls (default: 60)
VAULT_SYNC_INTERVAL=60

# Seconds between Needs_Action/ scans (Cloud Agent, default: 30)
SCAN_INTERVAL=30

# Seconds between Approved/ polls (Local Agent, default: 10)
APPROVAL_POLL_INTERVAL=10

# --- Task Lifecycle ---
# Minutes before an In_Progress/ file is considered stale and returned to Needs_Action/
STALE_TASK_TIMEOUT_MINUTES=30

# Hours before a Pending_Approval/ file expires and is auto-rejected
APPROVAL_EXPIRY_HOURS=24

# --- OpenAI (used by Cloud Agent for drafting) ---
OPENAI_API_KEY=sk-...
# Model for drafting email replies and social posts
OPENAI_MODEL=gpt-4o-mini

# --- Gmail ---
# Path to OAuth2 credentials file (from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=/path/to/credentials.json
# Path to OAuth2 token file (generated on first auth)
GMAIL_TOKEN_PATH=/path/to/token.json
# Gmail search query for inbox watching
GMAIL_QUERY=is:unread is:important

# --- WhatsApp (Local machine only) ---
# Directory where Playwright stores the WhatsApp Web session
WHATSAPP_SESSION_PATH=/path/to/whatsapp_session

# --- LinkedIn (Local machine only) ---
# Directory where Playwright stores the LinkedIn session
LINKEDIN_SESSION_PATH=/path/to/linkedin_session

# --- Odoo ---
# Base URL of the Odoo instance (Cloud VM)
ODOO_URL=https://ai.yourdomain.com
# Database name
ODOO_DB=odoo_db
# Admin username
ODOO_USER=admin
# Admin password
ODOO_PASSWORD=change_me
# Public domain for Caddy HTTPS (Cloud VM only)
ODOO_DOMAIN=ai.yourdomain.com
# Docker Compose PostgreSQL password (Cloud VM only)
ODOO_DB_PASSWORD=change_me_db

# --- Safety ---
# Set to "true" to skip all external sends (emails, posts, Odoo actions)
# Log what would have happened instead. USE IN DEVELOPMENT.
DRY_RUN=true
